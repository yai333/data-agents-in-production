# =============================================================================
# Text-to-SQL Agent Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (choose one as primary)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Default provider: openai or gemini
LLM_PROVIDER=openai

# Default model (provider-specific)
# OpenAI: gpt-4o-mini, gpt-4o, gpt-5-mini
# Gemini: gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Postgres (default for local development)
CHINOOK_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chinook

# Optional: BigQuery (for cloud track)
# GOOGLE_CLOUD_PROJECT=your-project-id
# BIGQUERY_DATASET=chinook

# -----------------------------------------------------------------------------
# Observability (Chapter 3.4)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# Langfuse — local Docker setup (docker compose -f docker-compose.langfuse.yml up -d)
LANGFUSE_PUBLIC_KEY=pk-lf-book-text-to-sql
LANGFUSE_SECRET_KEY=sk-lf-book-text-to-sql
LANGFUSE_HOST=http://localhost:3000

# Optional: LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=text-to-sql-agent

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
# Max rows returned per query
MAX_RESULT_ROWS=1000

# Query timeout in seconds
QUERY_TIMEOUT_SECONDS=30

# Enable PII detection (requires Presidio)
PII_DETECTION_ENABLED=true
